#!/bin/bash
# Athos — note rapide en session
# Usage: ./note "§learned:quelque_chose|val:x"
# Ou:    ./note  (ouvre éditeur si pas d'argument)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
ROOT="$(cd "$SCRIPT_DIR" >/dev/null 2>&1 && pwd)"
TEMP="$ROOT/temp/session_notes.mem"
mkdir -p "$(dirname "$TEMP")"

if [ -n "$1" ]; then
    echo "$1" >> "$TEMP"
    echo "§noted:ok"
else
    echo "§prompt:note_content:"
    read -r content
    echo "$content" >> "$TEMP"
    echo "§noted:ok"
fi
